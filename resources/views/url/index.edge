<!DOCTYPE html>
<html>
<head>
  <title>Mini Raccourcisseur d'URL</title>
</head>
<body>

  <h1>Mini Raccourcisseur d'URL</h1>

  <form method="POST" action="/shorten">
    {{ csrfField() }}

    <input 
      type="text" 
      name="url" 
      placeholder="Entrez une URL complète..."
      required
    />

    <button type="submit">Raccourcir</button>
  </form>

  @if(result)
    <h2> URL créée !</h2>
    <p><strong>URL originale :</strong> {{ result.originalUrl }}</p>
    <p><strong>URL courte :</strong> 
      <a href="{{ result.shortUrl }}" target="_blank">{{ result.shortUrl }}</a>
    </p>

    <p><strong>QR code :</strong></p>
    <img src="{{ result.qrCode }}" alt="QR code" width="200" />
    <p>
      <a href="/admin">Voir toutes les URLs</a>
    </p>
  @endif

</body>
</html>