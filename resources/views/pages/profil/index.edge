<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profil</title>
    <style>body{font-family:Arial,Helvetica,sans-serif} .profile{max-width:600px}</style>
</head>
<body>
    <h1>Profil Utilisateur</h1>
    <div class="profile">
        <h2>Informations Utilisateur</h2>
        <p>Nom: {{ user.name }}</p>
        <p>Email: {{ user.email }}</p>
        <div>
            <h3>QR Code</h3>
            <img src="{{ qrcode }}" alt="QR Code">
        </div>
    </div>
</body>
</html>