<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Créer une Actualité</title>
    <style>body{font-family:Arial,Helvetica,sans-serif} form{max-width:600px}</style>
</head>
<body>
    <h1>Créer une Actualité</h1>
    <form action="/actualites" method="POST">
        <label for="title">Titre:</label><br>
        <input type="text" id="title" name="title" required style="width:100%"><br><br>
        <label for="content">Contenu:</label><br>
        <textarea id="content" name="content" rows="6" required style="width:100%"></textarea><br><br>
        <button type="submit">Publier</button>
    </form>
</body>
</html>